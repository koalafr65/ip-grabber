def _logo_img(size, master=None):
    """Return tk.PhotoImage of logo at given size. NOT cached (each Tk root needs its own)."""
    try:
        import base64 as _b64, io
        from PIL import Image, ImageTk
        raw = Image.open(io.BytesIO(_b64.b64decode(_LOGO_B64))).convert("RGBA")
        sq = raw.resize((size, size), Image.LANCZOS)
        tk_img = ImageTk.PhotoImage(sq, master=master)
        return tk_img
    except:
        return None

def _logo_label(parent, size, bg=BG1):
    """Create a Label with the cloud logo at given size. Falls back to vector drawing."""
    try:
        root=parent.winfo_toplevel()
    except:
        root=None
    img = _logo_img(size, master=root)
    if img:
        lbl = tk.Label(parent, image=img, bg=bg, bd=0, highlightthickness=0)
        lbl._img_ref = img   # keep reference to prevent GC
        return lbl
    # Fallback: draw cloud vector inline via a small canvas
    cv = tk.Canvas(parent, width=size, height=size, bg=bg, highlightthickness=0)
    _draw_cloud_vector(cv, size)
    return cv

def _draw_cloud_vector(cv, size, color=TEAL):
    """Draw minimal vector cloud on a canvas widget."""
    import math as _m
    s = size
    def sc(nx, ny): return s*nx/100.0, s*ny/100.0
    def arc_pts(ox,oy,rx,ry,a1,a2,steps=20):
        pts=[]
        for i in range(steps+1):
            t=_m.radians(a1+(a2-a1)*i/steps);pts.append(ox+rx*_m.cos(t));pts.append(oy+ry*_m.sin(t))
        return pts
