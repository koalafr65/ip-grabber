class _DiscordRPC:
    def __init__(self,client_id):
        self.client_id=client_id;self._handle=None;self._ready=False;self._lock=_rpc_th.RLock()
    def _get_pipe(self):
        import ctypes,ctypes.wintypes
        GENERIC_RW=0xC0000000;OPEN_EXISTING=3
        kernel32=ctypes.windll.kernel32
        kernel32.CreateFileW.restype=ctypes.c_void_p  # must be c_void_p to get correct 64-bit handle
        for i in range(10):
            path=f"\\\\.\\pipe\\discord-ipc-{i}"
            h=kernel32.CreateFileW(path,GENERIC_RW,0,None,OPEN_EXISTING,0,None)
            # c_void_p returns signed Python int: INVALID_HANDLE_VALUE is -1 (not 0xFFFFFFFF/0xFFFFFFFFFFFFFFFF)
            if h is not None and h not in (0xFFFFFFFF, 0xFFFFFFFFFFFFFFFF, -1):
                return ctypes.wintypes.HANDLE(h)
        return None
    def _read_exact(self,handle,n):
        """Read exactly n bytes from pipe, looping as needed."""
        import ctypes,ctypes.wintypes
        # Extract raw handle value for WinAPI calls
        raw_h=handle.value if hasattr(handle,'value') else handle
        out=b""
        while len(out)<n:
            remaining=n-len(out)
            buf=ctypes.create_string_buffer(remaining)
            read=ctypes.wintypes.DWORD(0)
            ok=ctypes.windll.kernel32.ReadFile(raw_h,buf,remaining,ctypes.byref(read),None)
            if not ok or read.value==0:raise IOError("pipe read failed")
            out+=buf.raw[:read.value]
        return out
    def _send_raw(self,handle,op,payload):
        import ctypes,ctypes.wintypes
        # Extract raw handle value for WinAPI calls
        raw_h=handle.value if hasattr(handle,'value') else handle
        data=_rpc_json.dumps(payload).encode()
        header=_rpc_struct.pack('<II',op,len(data))
        buf=header+data
        written=ctypes.wintypes.DWORD(0)
        ok=ctypes.windll.kernel32.WriteFile(raw_h,buf,len(buf),ctypes.byref(written),None)
        if not ok:raise IOError("pipe write failed")
    def _recv_raw(self,handle):
        try:
            hdr=self._read_exact(handle,8)
            op,length=_rpc_struct.unpack('<II',hdr)
            body=self._read_exact(handle,length)
            return op,_rpc_json.loads(body.decode())
        except:return None,None
