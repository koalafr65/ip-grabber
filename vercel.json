# NICKNAME SETUP
# ════════════════════════════════════════════════════════════════════════════
class NickSetup(tk.Tk):
    W,H=460,300
    def __init__(self):
        super().__init__()
        self.result=None;self._alive=True
        self.title("Wind Queue — Setup");self.resizable(False,False);self.configure(bg=BG)
        self.overrideredirect(True)
        self.update_idletasks()
        sw=self.winfo_screenwidth();sh=self.winfo_screenheight()
        self.geometry(f"{self.W}x{self.H}+{(sw-self.W)//2}+{(sh-self.H)//2}")
        self.attributes("-topmost",True);_si(self);self.attributes("-alpha",0.)
        self._build()
        self._chars=list("WIND QUEUE");self._ci=0;self._title_built=""
        self._fadein_job=self.after(20,self._fade_in)

    def _close(self):
        self._alive=False
        try:
            for job in self.tk.call('after','info').split():
                try:self.after_cancel(job)
                except:pass
        except:pass
        try:self.quit()
        except:pass
        try:self.destroy()
        except:pass

    def _build(self):
        tk.Frame(self,bg=TEAL,height=3).pack(fill="x")
        outer=tk.Frame(self,bg=BG);outer.pack(fill="both",expand=True)
        tk.Frame(outer,bg=TEAL,width=3).pack(side="left",fill="y")
        main=tk.Frame(outer,bg=BG);main.pack(side="left",fill="both",expand=True)
        hdr=tk.Frame(main,bg=BG1);hdr.pack(fill="x")
        hi=tk.Frame(hdr,bg=BG1);hi.pack(fill="x",padx=20,pady=16)
        logo_w=_logo_label(hi,42,bg=BG1)
        logo_w.pack(side="left",padx=(0,12))
        tf=tk.Frame(hi,bg=BG1);tf.pack(side="left")
        self._title_lbl=tk.Label(tf,text="",font=F14B,fg=WHITE,bg=BG1);self._title_lbl.pack(anchor="w")
        tk.Label(tf,text="First time setup",font=F8,fg=MID,bg=BG1).pack(anchor="w")
        tk.Frame(hdr,bg=BORDER,height=1).pack(fill="x")
        body=tk.Frame(main,bg=BG,padx=20,pady=16);body.pack(fill="both",expand=True)
        tk.Label(body,text="Choose your nickname",font=F9,fg=SILVER,bg=BG,anchor="w").pack(anchor="w",pady=(0,4))
        tk.Label(body,text="It will be shown in the sidebar of every session.",
                 font=FB,fg=MID,bg=BG,anchor="w",wraplength=400).pack(anchor="w",pady=(0,12))
        wrap=tk.Frame(body,bg=BG3);wrap.pack(fill="x",pady=(0,4))
        self._ent=tk.Entry(wrap,font=F10B,fg=WHITE,bg=BG3,insertbackground=TEAL,relief="flat",bd=0)
        self._ent.pack(fill="x",ipady=10,padx=12)
        counter_row=tk.Frame(body,bg=BG);counter_row.pack(fill="x",pady=(2,4))
        self._err=tk.Label(counter_row,text="",font=FB,fg=RED2,bg=BG,anchor="w");self._err.pack(side="left")
        self._counter=tk.Label(counter_row,text="0/15",font=FB,fg=DIM,bg=BG,anchor="e");self._counter.pack(side="right")
        def _on_key(*a):
            n=len(self._ent.get());c=min(n,15)
            self._counter.config(text=f"{c}/15",fg=RED2 if n>15 else TEAL if n>0 else DIM)
        self._ent.bind("<KeyRelease>",_on_key)
        self._btn=PhBtn(body,text="CONTINUE",command=self._submit,style="primary",w=418,h=36,bg=BG)
        self._btn.pack(fill="x")
        self._ent.bind("<Return>",lambda e:self._submit())

    def _fade_in(self):
        if not self._alive:return
        try:
            if not self.winfo_exists():return
        except:return
        cur=self.attributes("-alpha");nxt=min(1.,cur+0.08)
        self.attributes("-alpha",nxt)
        if nxt<1.:self.after(14,self._fade_in)
        else:self._ent.focus();self.after(60,self._typewrite)

    def _typewrite(self):
        if not self._alive:return
        if self._ci<len(self._chars):
            self._title_built+=self._chars[self._ci];self._ci+=1
            col=TEAL if self._chars[self._ci-1]!=" " else WHITE
            self._title_lbl.config(text=self._title_built,fg=col)
            self.after(10,self._typewrite_reset)
        else:self._title_lbl.config(fg=WHITE)

    def _typewrite_reset(self):
        if not self._alive:return
        self._title_lbl.config(fg=WHITE);self.after(55,self._typewrite)

    def _submit(self):
        nick=self._ent.get().strip()
        if not nick:self._err.config(text="Please enter a nickname.");return
        if len(nick)<3:self._err.config(text="Min 3 characters.");return
        if len(nick)>15:self._err.config(text="Max 15 characters.");return
        import re
        if not re.match(r'^[a-zA-Z0-9_.\-]+$',nick):
            self._err.config(text="Only letters, numbers, _ . - allowed.");return
        self._err.config(text="Checking availability...",fg=SILVER if hasattr(self,'_err') else SILVER)
        self._btn.config(state="disabled");self.update()
        hw=_gh()
        if _check_nick_taken(nick,hw):
            self._err.config(text=f"Nickname '{nick}' is already taken.",fg=RED2)
            self._btn.config(state="normal");return
        self._err.config(text="")
        self.result=nick
        self.after(200,self._close)

