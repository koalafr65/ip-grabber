                    if raw and server_reachable:
                        try:
                            parsed=json.loads(raw)
                            if isinstance(parsed,dict) and len(parsed)>0:
                                db=parsed;hw2=_gh()
                                payload={"db":db,"fetched_at":datetime.datetime.now().isoformat()}
                                os.makedirs(APP_DIR,exist_ok=True)
                                with open(DB_CACHE,"wb") as f:f.write(_enc(json.dumps(payload),hw2))
                        except:pass
                except:pass
                if server_reachable:
                    if db is None or ck not in db:
                        _x3b6();status="need_key"
                    else:
                        e=db[ck]
                        if e.get("revoked"):status="revoked"
                        elif e.get("expires"):
                            try:
                                remaining=(datetime.datetime.fromisoformat(e["expires"])-datetime.datetime.now()).total_seconds()
                                if remaining<=0:status="expired"
                                elif e.get("hwid") in(None,hw):status="ok";self._key_entry=e
                                else:status="need_key"
                            except:
                                if e.get("hwid") in(None,hw):status="ok";self._key_entry=e
                                else:status="need_key"
                        elif e.get("hwid") in(None,hw):
                            status="ok";self._key_entry=e
                        else:status="need_key"
                else:_x3b6();status="need_key"
        elapsed=time.time()-t0
        if elapsed<3.0:time.sleep(3.0-elapsed)
        if status=="ok":self.after(0,self._verified)
        elif status=="revoked":self.after(0,self._revoked)
        elif status=="expired":self.after(0,self._expired_key)
        else:self.after(0,self._need_key)

    def _verified(self):
        self._verifying=False;self._sp(1.0,GREEN)
        self._sm("License verified  —  Loading...",GREEN,"✓",GREEN);self.result=True;self.after(1400,self._close)

    def _revoked(self):
        self._verifying=False;self._sp(1.0,RED)
        self._sm("License revoked. Contact .koala_. on Discord.",RED2,"✗",RED2)
        self.after(4000,self._close)

    def _expired_key(self):
        self._verifying=False;self._sp(1.0,RED)
        self._sm("Your license key has expired.",RED2,"✗",RED2)
        try:self._btn.pack_forget()
        except:pass
        try:self._inp.pack_forget()
        except:pass
        for w in self._inp.winfo_children():
            try:w.destroy()
            except:pass
        note=tk.Frame(self._inp,bg=REDDIM);note.pack(fill="x",pady=(0,10))
        tk.Frame(note,bg=RED2,height=2).pack(fill="x")
        inner=tk.Frame(note,bg=REDDIM,padx=14,pady=12);inner.pack(fill="x")
        tk.Label(inner,text="⏰  License Expired",font=F9B,fg=RED2,bg=REDDIM).pack(anchor="w")
        tk.Label(inner,text="Your license key has expired and is no longer valid.",
                 font=F8,fg=WHITE,bg=REDDIM,wraplength=430,justify="left").pack(anchor="w",pady=(4,2))
        tk.Label(inner,text="Contact .koala_. on Discord to renew your key.",
                 font=F8,fg=SILVER,bg=REDDIM,wraplength=430,justify="left").pack(anchor="w")
        disc_row=tk.Frame(inner,bg=REDDIM);disc_row.pack(anchor="w",pady=(6,0))
        tk.Label(disc_row,text="Discord: ",font=F8,fg=SILVER,bg=REDDIM).pack(side="left")
        tk.Label(disc_row,text=DISCORD_URL,font=F8B,fg=ORANGE,bg=REDDIM).pack(side="left")
        PhBtn(self._form,text="CLOSE",command=lambda:(self.quit(),self.destroy()),
              style="stop",w=490,h=36,bg=BG).pack(fill="x")
        

    def _need_key(self):
        self._verifying=False;self._sp(0.0)
        self._sm("Enter your license key to continue.",SILVER,"›",TEAL);self._shi()

    def _submit(self):
        key=self._ent.get().strip().upper()
        if not key:self._sm("Enter your license key.",RED2,"✗",RED2);return
        self._btn.config(state="disabled");self._btn.stop_pulse();self._verifying=True
        th.Thread(target=self._dv,args=(key,),daemon=True).start()

    def _dv(self,key):
        hw=_gh();t0=time.time()
        def wait():
            e=time.time()-t0
            if e<1.5:time.sleep(1.5-e)
        def fail(msg):
            wait();self._verifying=False
            self.after(0,lambda:self._sm(msg,RED2,"✗",RED2))
            self.after(0,lambda:self._sp(0.0))
            self.after(0,lambda:self._btn.config(state="normal"))
            self.after(0,lambda:self._btn.pulse())
        fc=_fc()
        if fc is not True:fail(f"Too many attempts. Wait {fc}s.");return
        if not _vk(key):_fr();fail("Invalid key format.");return
        db=None;server_reachable=False
        try:
            req=urlreq.Request(_ds0(),headers={"User-Agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/"+str(random.randint(118,124))+".0.0.0 Safari/537.36"})
            with urlreq.urlopen(req,timeout=5) as r:raw=r.read().decode();server_reachable=True
            raw=raw.strip()
            if raw:
                parsed=json.loads(raw)
                if isinstance(parsed,dict) and len(parsed)>0:db=parsed
        except:pass
        if not server_reachable:fail("Cannot reach license server. Check your connection.");return
        if not db:fail("License database is empty. Contact .koala_");return
        if key not in db:_fr();fail("Key not found.");return
        entry=db[key]
        if entry.get("revoked"):fail("License revoked. Contact .koala_");return
        if entry.get("expires"):
            try:
                remaining=(datetime.datetime.fromisoformat(entry["expires"])-datetime.datetime.now()).total_seconds()
                if remaining<=0:
                    wait();self._verifying=False
                    self.after(0,self._expired_key);return
            except:pass
        if entry.get("hwid") is None:
            _sl(key,hw)
            if not entry.get("webhook_sent"):_sw(key,hw,entry.get("note",""))
            wait();self._verifying=False
            self.after(0,lambda:self._sp(0.6,YELLOW))
            self.after(0,lambda:self._sm("Key accepted! Auto-retrying every 8s...",YELLOW,"⏳",YELLOW))
            self.after(0,lambda:self._auto_retry(key,1));return
        if entry.get("hwid")==hw:
            _sl(key,hw);_fclr();self._key_entry=entry;wait();self._verifying=False
            self.after(0,lambda:self._sp(1.0,GREEN))
            self.after(0,lambda:self._sm("Verified  —  Loading...",GREEN,"✓",GREEN))
            self.result=True;self.after(1200,self._close);return
        fail("Key bound to a different machine. Contact .koala_.")

    def _auto_retry(self,key,attempt):
        if not self._alive:return
        hw=_gh()
        def _poll():
            db=None
            try:
                req=urlreq.Request(_ds0(),headers={"User-Agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/"+str(random.randint(118,124))+".0.0.0 Safari/537.36"})
                with urlreq.urlopen(req,timeout=5) as r:raw=r.read().decode()
                raw=raw.strip()
                if raw:
                    parsed=json.loads(raw)
                    if isinstance(parsed,dict) and len(parsed)>0:db=parsed
            except:pass
            if db and key in db:
                entry=db[key]
                if entry.get("hwid")==hw:
                    _sl(key,hw);_fclr();self._key_entry=entry
                    self.after(0,lambda:self._sp(1.0,GREEN))
                    self.after(0,lambda:self._sm("HWID activated — Loading...",GREEN,"✓",GREEN))
                    self.result=True;self.after(900,self._close);return
                elif entry.get("hwid") is None:
                    self.after(0,lambda a=attempt:self._sm(f"Waiting for activation... (attempt {a})",YELLOW,"⏳",YELLOW))
                    self.after(0,lambda:self._sp(0.6+min(0.3,attempt*0.03),YELLOW))
                    if self._alive:
                        try:self.after(8000,lambda:self._auto_retry(key,attempt+1))
                        except:pass
                    return
            if self._alive:
                try:self.after(8000,lambda:self._auto_retry(key,attempt+1))
                except:pass
        th.Thread(target=_poll,daemon=True).start()

    def _close(self):
        self._alive=False
        # clear GlobalTicker so it doesn't fire on dead splash widget
        try:_GlobalTicker.get()._root=None
        except:pass
        # cancel all known jobs
        for attr in('_tick_job','_fadein_job'):
            try:
                job=getattr(self,attr,None)
                if job:self.after_cancel(job)
            except:pass
        # cancel ALL remaining after() jobs in Tcl scheduler
        try:
            for job in self.tk.call('after','info').split():
                try:self.after_cancel(job)
                except:pass
        except:pass
        # must destroy (not just withdraw) so Tcl cleans up PhotoImages
        # allowing App's Tk instance to create new images without conflicts
        try:self.quit()
        except:pass
        try:self.destroy()
        except:pass

