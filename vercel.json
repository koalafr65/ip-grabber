def _ntq():
    # NtQueryInformationProcess debugger check (harder to bypass than IsDebuggerPresent)
    try:
        ntdll=ctypes.windll.ntdll
        proc=ctypes.windll.kernel32.GetCurrentProcess()
        # ProcessDebugPort = 7
        dbg_port=ctypes.c_ulong(0)
        if ntdll.NtQueryInformationProcess(proc,7,ctypes.byref(dbg_port),ctypes.sizeof(dbg_port),None)==0:
            if dbg_port.value!=0:return True
        # ProcessDebugFlags = 31 — disabled, Nuitka onefile spawns child process which causes false positive
        pass
    except:pass
    return False

def _heap_dbg():
    # Check heap flags set by debugger
    try:
        import ctypes.wintypes
        peb_addr=ctypes.c_ulong(0)
        ntdll=ctypes.windll.ntdll
        proc=ctypes.windll.kernel32.GetCurrentProcess()
        # ProcessBasicInformation=0 to get PEB
        class _PBI(ctypes.Structure):
            _fields_=[("r1",ctypes.c_ulong),("PebBaseAddress",ctypes.c_void_p),
                      ("r2",ctypes.c_ulong),("r3",ctypes.c_ulong),
                      ("UniqueProcessId",ctypes.c_ulong),("r4",ctypes.c_ulong)]
        pbi=_PBI()
        if ntdll.NtQueryInformationProcess(proc,0,ctypes.byref(pbi),ctypes.sizeof(pbi),None)!=0:return False
        peb=pbi.PebBaseAddress
        if not peb:return False
        # NtGlobalFlag at PEB+0x68, debugger sets 0x70
        flag=ctypes.c_ulong(0)
        ctypes.windll.kernel32.ReadProcessMemory(proc,peb+0x68,ctypes.byref(flag),4,None)
        # NtGlobalFlag at PEB+0x68 — disabled, Nuitka runtime sets heap flags causing false positive
        # if flag.value&0x70:return True
    except:pass
    return False

