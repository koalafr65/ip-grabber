    def _show(self,tab,animated=True):
        if tab==self._cur_tab and animated:return
        if not hasattr(self,'_scroll_cache'):self._scroll_cache={}
        # save scroll of current tab
        if self._cur_tab:
            cv=self._tab_canvas(self._cur_tab)
            if cv:
                try:self._scroll_cache[self._cur_tab]=cv.yview()[0]
                except:pass
        self._cur_tab=tab
        for t,b in self._tabs.items():b.config(fg=TEAL if t==tab else SILVER,bg=BG2 if t==tab else BG1)
        for t,ic in self._rail_icons.items():
            ic._state="active" if t==tab else "idle"
            try:ic._draw(ic._state)
            except:pass
        self._pages[tab].tkraise()
        # restore scroll of new tab
        cv=self._tab_canvas(tab)
        if cv:
            pos=self._scroll_cache.get(tab,0.0)
            try:cv.after_idle(lambda c=cv,p=pos:c.yview_moveto(p))
            except:pass
        if tab=="profiles":
            cur_names=_lpr()
            if getattr(self,'_profiles_last_names',None)!=cur_names:
                self._profiles_last_names=cur_names
                self.after_idle(self._refresh_profiles)
            else:
                self.after_idle(self._refresh_profiles)

    def _tab_canvas(self,tab):
        """Return the scrollable canvas for a given tab, if any."""
        if tab=="profiles":return getattr(self,'_pf_cv',None)
        if tab=="sniper":return getattr(self,'_sniper_cv',None)
        if tab=="log":return None   # log uses Text widget, not canvas
        if tab=="about":return getattr(self,'_about_cv',None)
        return None


    def _get_join_response(self):
        if hasattr(self,'_ent_join_resp') and self._custom_labels_var.get():
            val=self._ent_join_resp.get().strip()
            if val:return val.lower()
        return bytes(b^0x5a for b in [35, 53, 47, 122, 59, 40, 63, 122, 59, 54, 40, 63, 59, 62, 35, 122, 51, 52, 122, 46, 50, 63, 122, 43, 47, 63, 47, 63]).decode()

    def _get_btn_labels(self):
        labels=["Join Queue"]
        if self._custom_labels_var.get():
            raw=self._ent_lbls.get()
            extras=[x.strip() for x in raw.split(",") if x.strip()]
            for e in extras:
                if e.lower()!="join queue":labels.append(e)
        return labels

    def _set_inputs_locked(self,locked:bool):
        try:
            self._ent_tok.set_locked(locked);self._ent_ch.set_locked(locked);self._ent_dly.set_locked(locked)
            self._toggle_widget.set_locked(locked)
            if locked:
                self._ent_lbls.config(state="readonly",readonlybackground=BG3,fg=MID,cursor="arrow",insertbackground=BG3)
                if hasattr(self,'_ent_join_resp'):self._ent_join_resp.config(state="readonly",readonlybackground=BG3,fg=MID,cursor="arrow",insertbackground=BG3)
            else:
                self._ent_lbls.config(state="normal",fg=WHITE,bg=BG3,cursor="xterm",insertbackground=TEAL)
                if hasattr(self,'_ent_join_resp'):self._ent_join_resp.config(state="normal",fg=WHITE,bg=BG3,cursor="xterm",insertbackground=TEAL)

            if locked:
                if not hasattr(self,'_lock_lbl') or not self._lock_lbl.winfo_exists():
                    self._lock_lbl=tk.Label(self._lock_lbl_anchor,text="🔒 Fields locked while running — press STOP to edit",
                                            font=F7,fg=ORANGE,bg=BG,anchor="w")
                self._lock_lbl.pack(fill="x",padx=2,pady=(2,0))
            else:
                if hasattr(self,'_lock_lbl'):
                    try:self._lock_lbl.pack_forget()
                    except:pass
        except Exception:pass

