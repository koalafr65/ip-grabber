class _GlobalTicker:
    """Single 16ms timer that drives ALL canvas animations — one after() instead of N."""
    _inst=None
    def __init__(self):
        self._fns=[];self._job=None;self._root=None
    @classmethod
    def get(cls):
        if cls._inst is None:cls._inst=cls()
        return cls._inst
    def init(self,root):
        # cancel previous root's job if switching windows (LicenseSplash → App)
        if self._job:
            try:
                if self._root:self._root.after_cancel(self._job)
            except:pass
            self._job=None
        self._root=root
        # clear PIL image caches — PhotoImage objects are tied to a specific Tk root
        # keeping stale images from the old root causes "invalid command name" errors
        for cls_name in('GlowDot','PhToggle'):
            try:globals()[cls_name]._img_cache.clear()
            except:pass
        try:self._job=self._root.after(100,self._tick)
        except:pass
    def register(self,fn):
        if fn not in self._fns:self._fns.append(fn)
    def unregister(self,fn):
        try:self._fns.remove(fn)
        except ValueError:pass
    def _tick(self):
        if not self._root:return
        try:
            if not self._root.winfo_exists():self._root=None;self._job=None;return
        except:self._root=None;self._job=None;return
        self._job=None
        dead=[]
        for fn in list(self._fns):
            try:fn()
            except tk.TclError:dead.append(fn)
            except:pass
        for fn in dead:self.unregister(fn)
        try:self._job=self._root.after(16,self._tick)
        except tk.TclError:self._root=None
        except:pass

