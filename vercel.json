def _gen_wav(notes):
    """Generate WAV bytes for a list of (freq_hz, duration_ms) notes."""
    import struct,math
    sr=44100;channels=1;bits=16
    frames=b""
    for freq,dur_ms in notes:
        n=int(sr*dur_ms/1000)
        fade=int(n*0.1)  # 10% fade in/out to avoid clicks
        for i in range(n):
            t=i/sr
            v=math.sin(2*math.pi*freq*t)
            # fade in
            if i<fade:v*=i/fade
            # fade out
            elif i>n-fade:v*=(n-i)/fade
            frames+=struct.pack('<h',int(v*28000))
        # small silence between notes
        frames+=b'\x00'*int(sr*0.03)*2
    # WAV header
    data_len=len(frames)
    hdr=struct.pack('<4sI4s4sIHHIIHH4sI',
        b'RIFF',36+data_len,b'WAVE',b'fmt ',16,1,channels,sr,
        sr*channels*bits//8,channels*bits//8,bits,b'data',data_len)
    return hdr+frames

