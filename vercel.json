class GlowDot(tk.Canvas):
    R=7
    _img_cache={}
    def __init__(self,parent,bg=BG1,**kw):
        super().__init__(parent,width=self.R*4,height=self.R*4,bg=bg,highlightthickness=0,**kw)
        self._col=MID;self._phase=0.;self._bg=bg;self._last_img=None;_Tk(self,self._draw,24).start()
    def set_color(self,c):self._col=c
    @classmethod
    def _dot_img(cls,r,color_hex,bg_hex,glow_layers=4,glow_alpha=0.22):
        """Render anti-aliased glow dot via 4x supersampling + LANCZOS."""
        key=(r,color_hex,bg_hex,glow_alpha)
        if key in cls._img_cache:return cls._img_cache[key]
        try:
            from PIL import Image,ImageDraw,ImageTk
            S=4;D=r*2*S
            bg_rgb=tuple(int(bg_hex.lstrip("#")[i:i+2],16) for i in(0,2,4))
            fg_rgb=tuple(int(color_hex.lstrip("#")[i:i+2],16) for i in(0,2,4))
            total=r*2+glow_layers*2
            img=Image.new("RGBA",(total*S,total*S),(bg_rgb[0],bg_rgb[1],bg_rgb[2],0))
            draw=ImageDraw.Draw(img)
            off=glow_layers*S
            for i in range(glow_layers,0,-1):
                a=int(255*glow_alpha*(i/glow_layers))
                draw.ellipse([off-i*S,off-i*S,off+D+i*S-1,off+D+i*S-1],fill=(fg_rgb[0],fg_rgb[1],fg_rgb[2],a))
            draw.ellipse([off,off,off+D-1,off+D-1],fill=(fg_rgb[0],fg_rgb[1],fg_rgb[2],255))
            img=img.resize((total,total),Image.LANCZOS)
            tk_img=ImageTk.PhotoImage(img)
            cls._img_cache[key]=tk_img
            return tk_img
        except:return None
    def _draw(self):
        self._phase=(self._phase+0.08)%(2*math.pi);pulse=0.5+0.5*math.sin(self._phase)
        self.delete("all");cx=cy=self.R*2;r=self.R
        try:
            from PIL import Image,ImageDraw,ImageTk
            # build per-frame blended color
            fg=self._col;bg=self._bg
            fg_rgb=tuple(int(fg.lstrip("#")[i:i+2],16) for i in(0,2,4))
            bg_rgb=tuple(int(bg.lstrip("#")[i:i+2],16) for i in(0,2,4))
            S=4;glow=4;total=r*2+glow*2
            img=Image.new("RGBA",(total*S,total*S),(bg_rgb[0],bg_rgb[1],bg_rgb[2],0))
            draw=ImageDraw.Draw(img)
            off=glow*S;D=r*2*S
            for i in range(glow,0,-1):
                a=int(255*0.25*pulse*(i/glow))
                draw.ellipse([off-i*S,off-i*S,off+D+i*S-1,off+D+i*S-1],fill=(fg_rgb[0],fg_rgb[1],fg_rgb[2],a))
            draw.ellipse([off,off,off+D-1,off+D-1],fill=(fg_rgb[0],fg_rgb[1],fg_rgb[2],255))
            img=img.resize((total,total),Image.LANCZOS)
            tk_img=ImageTk.PhotoImage(img)
            self._last_img=tk_img
            self.create_image(cx,cy,image=tk_img,anchor="center")
        except:
            # fallback canvas ovals
            for i in range(4,0,-1):
                a=_lc(self._bg,self._col,pulse*0.25*(i/4))
                self.create_oval(cx-r-i*2,cy-r-i*2,cx+r+i*2,cy+r+i*2,fill=a,outline="")
            self.create_oval(cx-r,cy-r,cx+r,cy+r,fill=self._col,outline="")

class ScanLine(tk.Canvas):
    _INTERVAL=12   # ms per frame (~83 fps)
    _SPEED=7.0     # px per frame — fast bounce
    _STEPS=14      # tail segment count
    _TAIL=90       # px full tail length
    _HEAD=4        # px half-width of bright head

    def __init__(self,parent,color=TEAL,always_on=False,**kw):
        super().__init__(parent,height=2,bg=BG,highlightthickness=0,**kw)
        self._x=0.0;self._dir=1;self._on=always_on
        self._cache_w=-1;self._segs=[]
        self.set_color(color)
        _Tk(self,self._draw,self._INTERVAL).start()

    def set_color(self,color):
        self._r0=int(color[1:3],16);self._g0=int(color[3:5],16);self._b0=int(color[5:7],16)
        self._cache_w=-1  # force seg rebuild next frame

    def start(self,color=None):
        if color:self.set_color(color)
        self._on=True

    def stop(self):
        self._on=False;self._x=0.0;self._dir=1
        try:self.delete("all")
        except tk.TclError:pass

    def _build_segs(self,w):
        step=self._TAIL//self._STEPS;segs=[]
        for i in range(self._STEPS):
            a=(1-(i/self._STEPS))**2
            segs.append((i*step,f"#{int(self._r0*a):02x}{int(self._g0*a):02x}{int(self._b0*a):02x}"))
        self._segs=segs;self._cache_w=w

    def _draw(self):
        if not self._on:return
        w=max(self.winfo_width(),300)
        self._x+=self._SPEED*self._dir
        if self._x>=w:self._x=float(w);self._dir=-1
        elif self._x<=0:self._x=0.0;self._dir=1
        x=int(self._x)
        if w!=self._cache_w:self._build_segs(w)
        self.delete("all")
        seg_w=self._TAIL//self._STEPS
        for offset,col in self._segs:
            px=x-offset*self._dir
            x1=max(0,min(w,int(px)));x2=max(0,min(w,int(px)+self._dir*seg_w))
            if x1!=x2:self.create_rectangle(min(x1,x2),0,max(x1,x2),2,fill=col,outline="")
        self.create_rectangle(max(0,x-self._HEAD),0,min(w,x+self._HEAD),2,fill=WHITE,outline="")

class PhToggle(tk.Canvas):
    """iOS/macOS-style toggle — entire widget rendered as one PIL image, 4x SS + LANCZOS."""
    W,H=52,28          # slightly larger — matches reference screenshot
    _img_cache={}      # (p_int, locked, bg_hex) -> tk.PhotoImage

    def __init__(self,parent,variable=None,command=None,bg=BG2,**kw):
        super().__init__(parent,width=self.W,height=self.H,
                         bg=bg,highlightthickness=0,cursor="hand2",**kw)
        self._var=variable or tk.BooleanVar(value=False);self._cmd=command
        self._anim=1. if self._var.get() else 0.;self._locked=False;self._bg=bg
        self._last_img=None;self._last_key=None
        _Tk(self,self._draw,14).start();self.bind("<Button-1>",self._click)

    def _click(self,e=None):
        if self._locked:return
        self._var.set(not self._var.get());(self._cmd and self._cmd())

    def get(self):return self._var.get()
    def set_locked(self,v):self._locked=v;self.configure(cursor="arrow" if v else "hand2")

    @classmethod
    def _get_knob(cls,d,color_hex,bg_hex):
        """Compat stub — kept so external code calling _get_knob still works."""
        return None

    @classmethod
    def _render_toggle(cls,W,H,p,locked,bg_hex):
        return None  # unused, kept for compat

    @classmethod
    def _render(cls,W,H,p,locked,bg_hex):
        """Render toggle pill — RGB, 4x supersampling + LANCZOS."""
        try:
            from PIL import Image,ImageDraw
            S=4;IW=W*S;IH=H*S
            bg_rgb=tuple(int(bg_hex.lstrip("#")[i:i+2],16) for i in(0,2,4))
            def lerp3(a,b,t):return tuple(int(a[i]+(b[i]-a[i])*t) for i in range(3))
            OFF=(38,40,52);ON=(0,179,222);BD_OFF=(55,58,75);BD_ON=(20,190,235)
            KN=(255,255,255) if not locked else (100,102,118)
            tc=lerp3(OFF,ON,p);bc=lerp3(BD_OFF,BD_ON,p)
            img=Image.new("RGB",(IW,IH),(bg_rgb[0],bg_rgb[1],bg_rgb[2]))
            draw=ImageDraw.Draw(img)
            r=IH//2
            # pill track
            draw.ellipse([0,0,IH-1,IH-1],     fill=tc)
            draw.ellipse([IW-IH,0,IW-1,IH-1], fill=tc)
            draw.rectangle([r,0,IW-r-1,IH-1], fill=tc)
            # border ~1px visible after LANCZOS downscale
            bw=5
            draw.arc([0,0,IH-1,IH-1],     start=90, end=270,fill=bc,width=bw)
            draw.arc([IW-IH,0,IW-1,IH-1], start=270,end=90, fill=bc,width=bw)
            draw.line([r,bw//2,   IW-r,bw//2],    fill=bc,width=bw)
            draw.line([r,IH-bw//2,IW-r,IH-bw//2], fill=bc,width=bw)
            # knob: 4px margin, knob fills remaining height
            MARGIN=4*S;KD=IH-2*MARGIN
            tx_off=MARGIN+KD//2;tx_on=IW-MARGIN-KD//2
            tx=int(tx_off+p*(tx_on-tx_off));ty=IH//2
            draw.ellipse([tx-KD//2,ty-KD//2,tx+KD//2,ty+KD//2],fill=KN)
            return img.resize((W,H),Image.LANCZOS)
        except:return None

    def _draw(self):
        target=1. if self._var.get() else 0.
        self._anim+=(target-self._anim)*0.22
        p=self._anim
        # quantise to 256 steps so cache stays small but animation looks smooth
        p_key=round(p*255)
        key=(p_key,self._locked,self._bg)
        if key==self._last_key and abs(target-self._anim)<0.003:return
        self._last_key=key
        img_pil=self._img_cache.get(key)
        if img_pil is None:
            from PIL import ImageTk
            raw=self._render(self.W,self.H,p,self._locked,self._bg)
            if raw:
                img_pil=ImageTk.PhotoImage(raw)
                self._img_cache[key]=img_pil
        if img_pil:
            self.delete("all")
            self.create_image(0,0,image=img_pil,anchor="nw")
            self._last_img=img_pil
        else:
            # minimal canvas fallback
            self.delete("all");W,H=self.W,self.H;r=H//2
            track=_lc(BG4,TEAL,p)
            self.create_arc(0,0,H,H,start=90,extent=180,fill=track,outline="")
            self.create_arc(W-H,0,W,H,start=270,extent=180,fill=track,outline="")
            self.create_rectangle(r,0,W-r,H,fill=track,outline="")
            tx=int(r+p*(W-H))
            self.create_oval(tx-(r-3),r-(r-3),tx+(r-3),r+(r-3),fill=WHITE,outline="")

class PhBtn(tk.Canvas):
    def __init__(self,parent,text="",command=None,style="default",w=110,h=34,bg=BG,**kw):
        super().__init__(parent,width=w,height=h,bg=bg,highlightthickness=0,bd=0,relief="flat",cursor="hand2",**kw)
        self._text=text;self._cmd=command;self._style=style
        self._hov=False;self._dis=False;self._flash=0.;self._anim=0.;self._bg=bg
        self._pulsing=False;self._pulse_v=0.;self._pulse_d=1
        self._last_key=None
        _Tk(self,self._draw,16).start()
        self.bind("<Enter>",lambda e:setattr(self,'_hov',True))
        self.bind("<Leave>",lambda e:setattr(self,'_hov',False))
        self.bind("<Button-1>",self._click)
    def config(self,**kw):
        if "state" in kw:self._dis=kw.pop("state")=="disabled"
        if kw:super().config(**kw)
    def pulse(self):self._pulsing=True
    def stop_pulse(self):self._pulsing=False;self._pulse_v=0.
    def _click(self,e):
        if not self._dis:self._flash=1.;(self._cmd and self._cmd())
    def _draw(self):
        if self._flash>0:self._flash=max(0.,self._flash-0.11)
        if self._pulsing:
            self._pulse_v+=0.055*self._pulse_d
            if self._pulse_v>=1.:self._pulse_d=-1
            elif self._pulse_v<=0.:self._pulse_d=1
        target=1. if(self._hov and not self._dis) else 0.
        self._anim+=(target-self._anim)*0.18
        W=int(self.cget("width"));H=int(self.cget("height"))
        g=min(1.,self._anim+self._flash*1.0+(self._pulse_v*0.45 if self._pulsing else 0))
        cache_key=(self._text,self._style,self._dis,W,H,int(g*100))
        moving=(self._flash>0.0 or self._pulsing or abs(target-self._anim)>0.01)
        if cache_key==self._last_key and not moving:return
        self._last_key=cache_key
        self.delete("all")
        if self._style=="primary":
            if self._dis:
                fill=_lc(BG3,BG4,0.5)
            else:
                fill=_lc("#071510",_lc("#0d2e24",TEALDIM,g*0.7),g)
            self.create_rectangle(1,1,W-1,H-1,fill=fill,outline="")
            if not self._dis:
                shine_col=_lc(TEALDIM,TEAL,g)
                self.create_rectangle(1,1,W-1,2,fill=shine_col,outline="")
            bar_col=_lc(TEAL2,TEAL,g) if not self._dis else DIM
            self.create_rectangle(1,1,4,H-1,fill=bar_col,outline="")
            bd=_lc(BORDER,TEAL,g*0.85) if not self._dis else BORDER
            self.create_rectangle(1,1,W-1,H-1,fill="",outline=bd,width=1)
            if not self._dis and g>0.15:
                self.create_rectangle(4,2,W-2,4,fill=_lc("#071510",TEALDIM,g),outline="")
        elif self._style=="stop":
            fill=_lc(BG2,_lc(BG3,"#1a0305",g*0.8),g)
            self.create_rectangle(1,1,W-1,H-1,fill=fill,outline="")
            bd=_lc(BORDER,RED2,g*0.9)
            self.create_rectangle(1,1,W-1,H-1,fill="",outline=bd,width=1)
            if g>0.1:
                self.create_rectangle(1,1,W-1,2,fill=_lc(BORDER,RED,g*0.6),outline="")
        else:
            fill=_lc(BG2,BG3,g)
            if self._style=="save":
                bd=_lc(BORDER,TEAL,g*0.9)
                self.create_rectangle(1,1,W-1,H-1,fill=fill,outline=bd,width=1)
                if g>0.05:
                    self.create_rectangle(1,1,W-1,2,fill=_lc(BORDER,TEAL,g*0.7),outline="")
            else:
                self.create_rectangle(1,1,W-1,H-1,fill=fill,outline=_lc(BORDER,BORDER2,g),width=1)
                if g>0.05:
                    self.create_rectangle(1,1,W-1,2,fill=_lc(BORDER,BORDER2,g*0.8),outline="")
        if self._dis:
            fc=DIM
        elif self._style=="primary":
            fc=_lc(SILVER,WHITE,g) if not self._dis else DIM
        elif self._style=="stop":
            fc=_lc(SILVER,WHITE,g)
        elif self._style=="save":
            fc=_lc(MID,TEAL,g)
        else:
            fc=_lc(MID,SILVER,g)
        self.create_text(W//2,H//2,text=self._text,font=F9B,fill=fc)

class PhSB(tk.Canvas):
    def __init__(self,parent,command=None,bg=BG,interactive=True,**kw):
        kw.pop("command",None)
        bg=kw.pop("bg",bg)
        super().__init__(parent,width=6,bg=bg,highlightthickness=0,**kw)
        self._cmd=command;self._s=0.;self._e=1.;self._dy=None;self._bg=bg
        self._anim_s=0.;self._anim_e=1.;self._hov=False;self._interactive=interactive;self._last_draw=None
        self.bind("<ButtonPress-1>",lambda e:setattr(self,'_dy',e.y) if self._interactive else None)
        self.bind("<ButtonRelease-1>",lambda e:setattr(self,'_dy',None))
        self.bind("<Enter>",lambda e:setattr(self,'_hov',True))
        self.bind("<Leave>",lambda e:setattr(self,'_hov',False))
        self.bind("<B1-Motion>",self._drag if self._interactive else (lambda e:None))
        self.bind("<Configure>",lambda e:self._rd())
        self.bind("<Destroy>",lambda e:_GlobalTicker.get().unregister(self._tick))
        _GlobalTicker.get().register(self._tick)
    def _tick(self):
        try:
            if not self.winfo_exists():
                _GlobalTicker.get().unregister(self._tick);return
        except:
            _GlobalTicker.get().unregister(self._tick);return
        spd=0.18
        self._anim_s+=(self._s-self._anim_s)*spd
        self._anim_e+=(self._e-self._anim_e)*spd
        self._rd()
    def configure(self,**kw):
        if "command" in kw:self._cmd=kw.pop("command")
        if kw:super().configure(**kw)
    def set(self,f,l):self._s=float(f);self._e=float(l)
    def _rd(self):
        try:
            h=self.winfo_height();w=self.winfo_width()
        except:return
        if h<4:return
        ty=int(self._anim_s*h);by=max(int(self._anim_e*h),ty+18)
        key=(w,h,ty,by,self._hov)
        if key==self._last_draw:return
        self._last_draw=key
        self.delete("all")
        self.create_rectangle(0,0,w,h,fill=self._bg,outline="")
        col=BG3 if self._hov else BG4
        self.create_rectangle(1,ty,w-1,by,fill=col,outline="")
        stripe=TEAL if self._hov else _lc(TEAL2,TEAL,0.5)
        self.create_rectangle(0,ty,2,by,fill=stripe,outline="")
    def _drag(self,e):
        if self._dy is None:return
        h=self.winfo_height()
        if h<=0:return
        delta=(e.y-self._dy)/h*0.35;self._dy=e.y
        if self._cmd:self._cmd("moveto",self._s+delta)

def _make_scroll(parent,bg=BG):
    cv=tk.Canvas(parent,bg=bg,highlightthickness=0)
    sb=PhSB(parent,command=None,bg=bg,interactive=False)
    cv.configure(yscrollcommand=sb.set)
    sb.pack(side="right",fill="y");cv.pack(side="left",fill="both",expand=True)
    inner=tk.Frame(cv,bg=bg)
    win_id=cv.create_window((0,0),window=inner,anchor="nw")
    inner.bind("<Configure>",lambda e:cv.configure(scrollregion=cv.bbox("all")))
    cv.bind("<Configure>",lambda e:cv.itemconfig(win_id,width=e.width))
    def _mw(e):
        if e.delta==0:return "break"
        cv.yview_scroll(int(-1*(e.delta/abs(e.delta)))*3,"units")
        return "break"
    def _bind_tree(w):
        try:w.bind("<MouseWheel>",_mw,add="+")
        except:pass
        try:
            for ch in w.winfo_children():_bind_tree(ch)
        except:pass
    cv.bind("<MouseWheel>",_mw,add="+")
    inner.bind("<MouseWheel>",_mw,add="+")
    cv.after_idle(_bind_tree,inner)
    return cv,inner

