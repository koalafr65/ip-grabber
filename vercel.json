                    except:pass
                    time.sleep(2);os._exit(1)
            except:pass
            time.sleep(random.uniform(270,330))
    th.Thread(target=_watch,daemon=True).start()


def _ve():
    sig_file=os.path.join(APP_DIR,"exe.sig")
    try:
        h=hashlib.sha256()
        with open(sys.executable,"rb") as f:
            for chunk in iter(lambda:f.read(65536),b""):h.update(chunk)
        cur=h.hexdigest()
    except:return
    os.makedirs(APP_DIR,exist_ok=True)
    if not os.path.exists(sig_file):
        sig=hmac.new(_gs().encode(),cur.encode(),hashlib.sha256).hexdigest()
        with open(sig_file,"w") as f:json.dump({"h":cur,"s":sig},f)
        return
    try:
        with open(sig_file) as f:d=json.load(f)
        expected=hmac.new(_gs().encode(),d["h"].encode(),hashlib.sha256).hexdigest()
        if not hmac.compare_digest(d["s"],expected):_se()
        if not hmac.compare_digest(cur,d["h"]):
            os.remove(sig_file);sig=hmac.new(_gs().encode(),cur.encode(),hashlib.sha256).hexdigest()
            with open(sig_file,"w") as f:json.dump({"h":cur,"s":sig},f)
    except:pass

