        self._ready=False
        if self._handle is not None:
            try:
                import ctypes as _ct
                raw_h=self._handle.value if hasattr(self._handle,'value') else self._handle
                _ct.windll.kernel32.CloseHandle(raw_h)
            except:pass
            self._handle=None
    def connect(self):
        self._close_handle()
        self._handle=self._get_pipe()
        if not self._handle:return False
        try:
            self._send_raw(self._handle,0,{"v":1,"client_id":self.client_id})
            op,data=self._recv_raw(self._handle)
            if data and data.get('evt')=='READY':self._ready=True;return True
        except:pass
        self._close_handle();return False
    def _try_reconnect(self):
        """Try to reconnect once if pipe is dead. Returns True if now ready."""
        if self._ready:return True
        return self.connect()
    def update(self,details=None,state=None,start=None):
        with self._lock:
            if not self._ready and not self._try_reconnect():return
            payload={"cmd":"SET_ACTIVITY","args":{"pid":_rpc_os.getpid(),"activity":{"type":0,"details":details or "Contact .koala_. to purchase","state":state or "","timestamps":{"start":int(start or _rpc_time.time())},"assets":{"large_image":"windqueue","large_text":"Contact .koala_. to purchase"},"buttons":[{"label":"Purchase Yours Here","url":"https://discord.gg/bg66ByUEWt"}]}},"nonce":str(_rpc_uuid.uuid4())}
            try:
                self._send_raw(self._handle,1,payload)
                self._recv_raw(self._handle)
            except:
                self._close_handle()  # mark dead; next call will reconnect
    def clear(self):
        with self._lock:
            if not self._ready:return
            try:
                self._send_raw(self._handle,1,{"cmd":"SET_ACTIVITY","args":{"pid":_rpc_os.getpid(),"activity":None},"nonce":str(_rpc_uuid.uuid4())})
                self._recv_raw(self._handle)
            except:
                self._close_handle()
    def close(self):
        with self._lock:
            self._close_handle()

