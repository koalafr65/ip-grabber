def _online_lic_check(key,hw):
    try:
        req=urlreq.Request(_ds0(),headers={"User-Agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/"+str(random.randint(118,124))+".0.0.0 Safari/537.36"})
        with urlreq.urlopen(req,timeout=6) as r:raw=r.read().decode().strip()
        if not raw:return True
        db=json.loads(raw)
        if not isinstance(db,dict):return True
        entry=db.get(key)
        if entry is None:return False
        if entry.get("revoked"):return False
        if entry.get("hwid") and entry.get("hwid")!=hw:return False
        if entry.get("expires"):
            try:
                remaining=(datetime.datetime.fromisoformat(entry["expires"])-datetime.datetime.now()).total_seconds()
                if remaining<=0:return False
            except:pass
        return True
    except:return True

