# MAIN APP
# ════════════════════════════════════════════════════════════════════════════
class App(tk.Tk):
    TABS=[("sniper","Sniper"),("profiles","Profiles"),("log","Log"),("about","About")]
    TAB_ICONS={"sniper":"⚡","profiles":"⊞","log":"◈","about":"✦"}

    def __init__(self,nick="user",lic_entry=None):
        super().__init__()
        try:ctypes.windll.shcore.SetProcessDpiAwareness(1)
        except:pass
        self._nick=nick;self._lic=lic_entry or {}
        self.title("Wind Queue");self.geometry("1100x700");self.minsize(900,580)
        self.configure(bg=BG);_si(self);self.protocol("WM_DELETE_WINDOW",self._quit)
        self._running=False;self._client=None;self._clicks=0;self._started=None
        self._stat_lbl={};self._cur_tab=None
        self.attributes("-alpha",0.)
        # Start single global animation ticker — replaces N individual after() timers
        _GlobalTicker.get().init(self)
        # Pre-warm HWID cache in background so START click never blocks on WMI
        th.Thread(target=_gh,daemon=True).start()
        self._build()
        self.after(60,self._fadein)
        self.after(200,self._auto_load_last)

    def _auto_load_last(self):
        last_file=os.path.join(APP_DIR,'last_profile.txt')
        loaded=False
        try:
            with open(last_file,'r',encoding='utf-8') as f:name=f.read().strip()
            if name and _ldp(name):self._load_profile(name);loaded=True
        except:pass
        if not loaded:
            try:
                import json as _js2
                _sess_path=os.path.join(APP_DIR,'last_session.dat')
                _sess_path_old=os.path.join(APP_DIR,'last_session.json')
                if os.path.exists(_sess_path):
                    hw=_gh()
                    with open(_sess_path,'rb') as _sf:_sess_raw=_sf.read()
                    _sess_plain=_dec(_sess_raw,hw)
                    d=_js2.loads(_sess_plain) if _sess_plain else {}
                elif os.path.exists(_sess_path_old):
                    with open(_sess_path_old,'r',encoding='utf-8') as _sf:d=_js2.load(_sf)
                else:
                    d={}
                if d.get('token'):self._ent_tok.delete(0,'end');self._ent_tok.insert(0,d['token'])
                if d.get('channels'):self._ent_ch.delete(0,'end');self._ent_ch.insert(0,d['channels'])
            except:pass
        # start passive queue-position polling after session is loaded
        self.after(1200,self._x8a5)

    def _fadein(self):
        cur=self.attributes("-alpha");nxt=min(1.,cur+0.055)
        self.attributes("-alpha",nxt)
        if nxt<1.:self.after(14,self._fadein)

    def _build(self):
        tk.Frame(self,bg=TEAL,height=3).pack(fill="x")
        self._build_tb()
        tk.Frame(self,bg=BORDER,height=1).pack(fill="x")
        self._build_tabbar()
        tk.Frame(self,bg=BORDER,height=1).pack(fill="x")
        body=tk.Frame(self,bg=BG);body.pack(fill="both",expand=True)
        self._build_sidebar(body)
        self._content=tk.Frame(body,bg=BG)
        self._content.pack(side="left",fill="both",expand=True)
        self._content.grid_rowconfigure(0,weight=1)
        self._content.grid_columnconfigure(0,weight=1)
        self._pages={"sniper":self._pg_sniper(),"profiles":self._pg_profiles(),
                     "log":self._pg_log(),"about":self._pg_about()}
        for page in self._pages.values():
            page.grid(row=0,column=0,sticky="nsew")
        self._show("sniper",animated=False);self._ticker()

    def _build_tb(self):
        bar=tk.Frame(self,bg=BG1,height=80);bar.pack(fill="x");bar.pack_propagate(False)
        left=tk.Frame(bar,bg=BG1);left.pack(side="left",padx=14,pady=9)
