        PhBtn(bf2,text="SAVE",command=self._save_profile,style="save",w=90,h=34,bg=BG).pack(side="left")
        _div(fi);_shdr(fi,"DISCORD RPC",TEAL)
        rpc_row=tk.Frame(fi,bg=BG);rpc_row.pack(fill="x",pady=(4,8),padx=0)
        self._rpc_var=tk.BooleanVar(value=False)
        def _toggle_rpc():
            val=self._rpc_var.get()  # PhToggle already toggled the var
            self._rpc_lbl.config(fg=WHITE if val else SILVER)
            if val:
                if self._running:
                    _names=getattr(self,'_ch_names',{})
                    _client=getattr(self,'_client',None)
                    active=getattr(_client,'_ac3z',None)
                    if not active and _names:active=next(iter(_names))
                    if active and active in _names:
                        state=f"Sniping: {_names[active][1]}"
                    else:
                        state="Sniping the queue..."
                else:
                    state="Idle"
                ts=self._started or _rpc_time.time()
                th.Thread(target=_x0d6,args=(ts,),kwargs={"state":state},daemon=True).start()
            else:
                th.Thread(target=_x4b1,daemon=True).start()
        self._rpc_canvas=PhToggle(rpc_row,variable=self._rpc_var,command=_toggle_rpc,bg=BG)
        self._rpc_canvas.pack(side="left",padx=(0,10))
        self._rpc_lbl=tk.Label(rpc_row,text="Show activity in Discord profile",font=("Segoe UI",8),fg=SILVER,bg=BG)
        self._rpc_lbl.pack(side="left")
        self._rpc_lbl.bind("<Button-1>",lambda e:self._rpc_canvas._click())
        tk.Label(fi,text="⚠  Requires Activity Sharing enabled in Discord Settings → Activity Privacy",font=("Segoe UI",7),fg=DIM,bg=BG,anchor="w",wraplength=380,justify="left").pack(fill="x",padx=2,pady=(0,4))
        _div(fi);_shdr(fi,"STATS")
        self._r_clicks=PropRow(fi,label="Clicks",value="0");self._r_clicks.pack(fill="x",pady=1)
        self._r_fastest=PropRow(fi,label="Fastest Click",value="—");self._r_fastest.pack(fill="x",pady=1)
        self._r_avg=PropRow(fi,label="Avg Response",value="—");self._r_avg.pack(fill="x",pady=1)
        self._r_qpos=PropRow(fi,label="Queue Position",value="—");self._r_qpos.pack(fill="x",pady=1)
        _div(fi);_shdr(fi,"WATCHING",TEAL)
        self._wf=tk.Frame(fi,bg=BG);self._wf.pack(fill="x")
        tk.Label(self._wf,text="No channels configured",font=F9,fg=DIM,bg=BG).pack(anchor="w",padx=14,pady=5)
        RC=tk.Frame(cols,bg=BG);RC.pack(side="left",fill="both",expand=True)
        rch=tk.Frame(RC,bg=BG2);rch.pack(fill="x")
        # ── macOS-style traffic light dots (PIL anti-aliased) ─────────────
        _DOT_D=12   # diameter px
        _DOT_PAD=4  # spacing between dots
        _BRIGHT=[RED2, YELLOW, GREEN]
        _DIM_C =["#3a1215","#2e2200","#0d2e12"]
        _BG2_RGB=tuple(int(BG2.lstrip("#")[i:i+2],16) for i in(0,2,4))

        def _make_dot_img(color_hex):
            """Render one anti-aliased circle on BG2 background using PIL 4x supersampling + LANCZOS."""
            from PIL import Image,ImageDraw,ImageTk
            S=4;D=_DOT_D*S
            img=Image.new("RGB",(D,D),color=_BG2_RGB)
            draw=ImageDraw.Draw(img)
            r=tuple(int(color_hex.lstrip("#")[i:i+2],16) for i in(0,2,4))
            draw.ellipse([0,0,D-1,D-1],fill=r,outline=None)
            img=img.resize((_DOT_D,_DOT_D),Image.LANCZOS)
            return ImageTk.PhotoImage(img)

        # pre-render dim images for each dot
        _dim_imgs=[_make_dot_img(_DIM_C[i]) for i in range(3)]
        _dot_labels=[]
        dots_frame=tk.Frame(rch,bg=BG2)
        dots_frame.pack(side="left",padx=(10,0),pady=0)
        for i in range(3):
            lbl=tk.Label(dots_frame,image=_dim_imgs[i],bg=BG2,bd=0,highlightthickness=0)
            lbl.pack(side="left",padx=(_DOT_PAD//2,_DOT_PAD//2))
            lbl._imgref=_dim_imgs[i]
            _dot_labels.append(lbl)

        # cache of rendered colors to avoid re-rendering same hex
        _img_cache={}
        def _dot_img_cached(hex_col):
            if hex_col not in _img_cache:
                _img_cache[hex_col]=_make_dot_img(hex_col)
            return _img_cache[hex_col]

        _ACTIVE_DOT={"IDLE":-1,"CONNECTING":1,"RUNNING":2,"SUCCESS":2,"STOPPED":0}
        _phase=[0.0]

        def _dots_tick():
            try:
                if not dots_frame.winfo_exists():return
            except:return
            status=getattr(self,'_current_status','IDLE')
            active=_ACTIVE_DOT.get(status,-1)
            _phase[0]+=0.15
            t=(math.sin(_phase[0])*0.5+0.5)**1.5
            for i in range(3):
                if i==active:
                    bc=_BRIGHT[i];dc=_DIM_C[i]
                    br=int(int(bc[1:3],16)*t+int(dc[1:3],16)*(1-t))
                    bg_c=int(int(bc[3:5],16)*t+int(dc[3:5],16)*(1-t))
                    bb=int(int(bc[5:7],16)*t+int(dc[5:7],16)*(1-t))
                    col="#{:02x}{:02x}{:02x}".format(br,bg_c,bb)
                else:
                    col=_DIM_C[i]
                img=_dot_img_cached(col)
                _dot_labels[i].config(image=img)
                _dot_labels[i]._imgref=img
            try:dots_frame.after(16,_dots_tick)
            except:pass

        self._current_status='IDLE'
        try:dots_frame.after(200,_dots_tick)
        except:pass
        tk.Label(rch,text="Live Log",font=F9B,fg=TEAL,bg=BG2,padx=8,pady=8).pack(side="left")
        PhBtn(rch,text="CLEAR",command=self._clear_log,style="default",w=70,h=26,bg=BG2).pack(side="right",padx=8,pady=4)
        tf=tk.Frame(RC,bg="#090a0c");tf.pack(fill="both",expand=True)
        tsb=PhSB(tf,bg="#090a0c");tsb.pack(side="right",fill="y")
        self.term=tk.Text(tf,font=MONO,bg="#090a0c",fg="#1a1a2a",insertbackground=RED,
                          relief="flat",bd=0,state="disabled",wrap="word",spacing1=4,spacing3=2,
                          padx=10,pady=8,yscrollcommand=tsb.set)
        self.term.pack(side="left",fill="both",expand=True);tsb.configure(command=self.term.yview)
        def _term_mw(e):
            if e.delta==0:return
            self.term.yview_scroll(int(-1*(e.delta/abs(e.delta)))*3,"units")
        self.term.bind("<MouseWheel>",_term_mw)
        self._stags(self.term);return page

    def _toggle_custom_labels(self):
        if self._custom_labels_var.get():self._cl_panel.pack(fill="x",after=self._cl_anchor)
        else:self._cl_panel.pack_forget()

    def _stags(self,w):
        for tag,fg in[("sys",TEAL),("ok",GREEN),("click",YELLOW),("warn",ORANGE),
                      ("err",RED2),("dim","#2a2a40"),("ts","#1a1a30"),("bright",GREEN),("info",BLUE)]:
            w.tag_config(tag,foreground=fg)

    def _uw(self,ch_ids,names=None):
        if names:self._ch_names=dict(names)
        eff_names=(names if names is not None else getattr(self,"_ch_names",{}))
        # Avoid full list re-render when content did not change.
        try:
            sig=(tuple(ch_ids),tuple(sorted(eff_names.items())))
        except:
            sig=(tuple(ch_ids),())
        if getattr(self,"_watch_sig",None)==sig:return
        self._watch_sig=sig
        for w in self._wf.winfo_children():w.destroy()
        if not ch_ids:
            tk.Label(self._wf,text="No channels configured",font=F9,fg=DIM,bg=BG).pack(anchor="w",padx=14,pady=5);return
        for cid in ch_ids:
            row=tk.Frame(self._wf,bg=BG1);row.pack(fill="x",pady=1)
            inner=tk.Frame(row,bg=BG1);inner.pack(fill="x",padx=14,pady=6)
            tk.Label(inner,text="●",font=("Segoe UI",8),fg=GREEN,bg=BG1).pack(side="left",padx=(0,6))
            info=eff_names.get(cid)
            if info:
                ch_name,guild=info;tf2=tk.Frame(inner,bg=BG1);tf2.pack(side="left")
                tk.Label(tf2,text=f"#{ch_name}",font=F9B,fg=WHITE,bg=BG1).pack(anchor="w")
                _g=guild if len(guild)<=32 else guild[:30]+"…"
                tk.Label(tf2,text=_g,font=F7,fg=MID,bg=BG1).pack(anchor="w")
            else:tk.Label(inner,text=f"#{cid}",font=MONO,fg=SILVER,bg=BG1).pack(side="left")

    def _pg_profiles(self):
        page=tk.Frame(self._content,bg=BG)
        cf=tk.Frame(page,bg=BG1,height=32);cf.pack(side="bottom",fill="x");cf.pack_propagate(False);_fbar(cf)
        shdr=tk.Frame(page,bg=BG1);shdr.pack(fill="x")
