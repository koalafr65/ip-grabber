                  "vmcheck.dll","wpespy.dll","hookeddll.dll","frida-agent.dll","frida.dll",
                  "winspy.dll","inspector.dll","snxhk.dll","guard32.dll"}
        snap=ctypes.windll.kernel32.CreateToolhelp32Snapshot(0x08,0)  # TH32CS_SNAPMODULE
        if snap==-1:return False
        class _ME32(ctypes.Structure):
            _fields_=[("dwSize",ctypes.c_ulong),("th32ModuleID",ctypes.c_ulong),
                      ("th32ProcessID",ctypes.c_ulong),("GlblcntUsage",ctypes.c_ulong),
                      ("ProccntUsage",ctypes.c_ulong),("modBaseAddr",ctypes.c_void_p),
                      ("modBaseSize",ctypes.c_ulong),("hModule",ctypes.c_void_p),
                      ("szModule",ctypes.c_char*256),("szExePath",ctypes.c_char*260)]
