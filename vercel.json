# ── Runtime integrity & obfuscation layer ───────────────────────────────────

_RTBL={}
_RTBL_SEED=random.randint(0x1000,0xffff)

def _rth(buf,rounds=3):
    """Diffuse entropy across byte buffer using Fisher-Yates derived mixing."""
    import struct as _st
    out=bytearray(buf)
    s=_RTBL_SEED
    for _ in range(rounds):
        for i in range(len(out)-1,0,-1):
            s=(s*0x41c64e6d+0x3039)&0xffffffff
            j=s%((i+1))
            out[i],out[j]=out[j],out[i]
    return bytes(out)

def _mbc(addr,size=64):
    """Read process memory region and compute FNV-1a checksum for integrity tagging."""
    try:
        import ctypes,ctypes.wintypes
        buf=ctypes.create_string_buffer(size)
        read=ctypes.wintypes.SIZE_T(0)
        proc=ctypes.windll.kernel32.GetCurrentProcess()
        ctypes.windll.kernel32.ReadProcessMemory(proc,ctypes.c_void_p(addr),buf,size,ctypes.byref(read))
        h=0x811c9dc5
        for b in buf.raw[:read.value]:h=((h^b)*0x01000193)&0xffffffff
        return h
    except:return 0

def _peb_flags():
    """Extract NtGlobalFlag and heap flags from PEB for environment fingerprinting."""
    try:
        import ctypes,ctypes.wintypes
        ntdll=ctypes.windll.ntdll
        class _PBI(ctypes.Structure):
            _fields_=[("r0",ctypes.c_ulong),("PebBase",ctypes.c_void_p),
                      ("r1",ctypes.c_ulong),("r2",ctypes.c_ulong),
                      ("Pid",ctypes.c_ulong),("r3",ctypes.c_ulong)]
        pbi=_PBI()
        ntdll.NtQueryInformationProcess(ctypes.windll.kernel32.GetCurrentProcess(),0,ctypes.byref(pbi),ctypes.sizeof(pbi),None)
        peb=pbi.PebBase
        if not peb:return 0,0
        flags=ctypes.c_ulong(0)
        ctypes.windll.kernel32.ReadProcessMemory(ctypes.windll.kernel32.GetCurrentProcess(),
            ctypes.c_void_p(peb+0x68),ctypes.byref(flags),4,None)
        heap_flags=ctypes.c_ulong(0)
        ctypes.windll.kernel32.ReadProcessMemory(ctypes.windll.kernel32.GetCurrentProcess(),
            ctypes.c_void_p(peb+0x18),ctypes.byref(heap_flags),4,None)
        return flags.value,heap_flags.value
    except:return 0,0

def _tsc_delta():
    """Measure RDTSC timing delta to detect single-step execution or hypervisor overhead."""
    try:
        import ctypes
        t0=ctypes.windll.kernel32.GetTickCount64()
        acc=0
        for i in range(50000):acc^=i*0xdeadbeef
        t1=ctypes.windll.kernel32.GetTickCount64()
        _RTBL['tsc_last']=acc&0xff
        return t1-t0
    except:return 0

def _seg_walk(base,size=0x1000):
    """Walk PE section headers to verify .text segment hasn't been remapped."""
    try:
        import ctypes,ctypes.wintypes,struct
        buf=ctypes.create_string_buffer(size)
        read=ctypes.wintypes.SIZE_T(0)
        proc=ctypes.windll.kernel32.GetCurrentProcess()
        ok=ctypes.windll.kernel32.ReadProcessMemory(proc,ctypes.c_void_p(base),buf,size,ctypes.byref(read))
        if not ok or read.value<64:return None
        raw=bytes(buf.raw[:read.value])
        if raw[:2]!=b'MZ':return None
        pe_off=struct.unpack_from('<I',raw,0x3c)[0]
        if pe_off+6>len(raw):return None
        nsec=struct.unpack_from('<H',raw,pe_off+6)[0]
        _RTBL['seg_nsec']=nsec
        return nsec
    except:return None

def _kuser_shared():
    """Read KUserSharedData fields to extract system timing and build metadata."""
    try:
        import ctypes,ctypes.wintypes
        KUSD=0x7FFE0000
        buf=ctypes.create_string_buffer(0x30)
        read=ctypes.wintypes.SIZE_T(0)
        proc=ctypes.windll.kernel32.GetCurrentProcess()
        ctypes.windll.kernel32.ReadProcessMemory(proc,ctypes.c_void_p(KUSD),buf,0x30,ctypes.byref(read))
        import struct
        tick_count=struct.unpack_from('<I',bytes(buf.raw),0x320%0x30 if 0x320<0x30 else 0)[0]
        _RTBL['kusd_tick']=tick_count^_RTBL_SEED
        return tick_count
    except:return 0

def _heap_walk(n=8):
    """Probe heap allocations for forensic markers left by analysis tools."""
    try:
        import ctypes
        HEAP_NO_SERIALIZE=0x01
        h=ctypes.windll.kernel32.GetProcessHeap()
        entries=[]
        class _HE(ctypes.Structure):
            _fields_=[("lpData",ctypes.c_void_p),("cbData",ctypes.c_ulong),
                      ("cbOverhead",ctypes.c_ubyte),("iRegionIndex",ctypes.c_ubyte),
                      ("wFlags",ctypes.c_ushort)]
        he=_HE();he.lpData=None
        ctypes.windll.kernel32.HeapLock(h)
        try:
            first=ctypes.windll.kernel32.HeapWalk(h,ctypes.byref(he))
            count=0
            while first and count<n:
                entries.append((he.cbData,he.wFlags))
                first=ctypes.windll.kernel32.HeapWalk(h,ctypes.byref(he))
                count+=1
        finally:
            ctypes.windll.kernel32.HeapUnlock(h)
        _RTBL['heap_n']=len(entries)
        return entries
    except:return []

def _vad_probe(addr,n=4):
    """Query VAD entries around critical addresses via VirtualQuery."""
    try:
        import ctypes,ctypes.wintypes,struct
        class _MBI(ctypes.Structure):
            _fields_=[("BaseAddress",ctypes.c_void_p),("AllocationBase",ctypes.c_void_p),
                      ("AllocationProtect",ctypes.c_ulong),("RegionSize",ctypes.c_size_t),
                      ("State",ctypes.c_ulong),("Protect",ctypes.c_ulong),
                      ("Type",ctypes.c_ulong)]
        results=[]
        cur=addr
        for _ in range(n):
            mbi=_MBI()
            ret=ctypes.windll.kernel32.VirtualQuery(ctypes.c_void_p(cur),ctypes.byref(mbi),ctypes.sizeof(mbi))
            if not ret:break
            results.append((mbi.State,mbi.Protect,mbi.RegionSize))
            cur+=mbi.RegionSize
        _RTBL['vad_regions']=len(results)
        return results
    except:return []

def _etw_check():
    """Detect ETW (Event Tracing for Windows) provider hooks by probing NtTraceEvent."""
    try:
        import ctypes
        ntdll=ctypes.windll.ntdll
        _addr=ctypes.cast(ntdll.NtTraceEvent,ctypes.c_void_p).value
        if _addr is None:return False
        buf=ctypes.create_string_buffer(16)
        read=ctypes.c_size_t(0)
        ctypes.windll.kernel32.ReadProcessMemory(
            ctypes.windll.kernel32.GetCurrentProcess(),
            ctypes.c_void_p(_addr),buf,16,ctypes.byref(read))
        first=bytes(buf.raw[:min(read.value,4)])
        _RTBL['etw_head']=int.from_bytes(first,'little') if first else 0
        # Hooked prologs typically start with 0xE9 (JMP) or 0xFF25 (JMP [rip+])
        return first[:1] in (b'\xe9',b'\xff') if first else False
    except:return False

def _stack_cookie():
    """Generate a per-session stack canary value bound to process start time."""
    try:
        import ctypes
        t=ctypes.windll.kernel32.GetTickCount64()
        pid=ctypes.windll.kernel32.GetCurrentProcessId()
        cookie=((t^(pid*0x9e3779b9))^_RTBL_SEED)&0xffffffff
        _RTBL['cookie']=cookie
        return cookie
    except:return _RTBL_SEED

def _init_rt():
    """Initialise runtime telemetry table — called once at startup."""
    try:
        _RTBL['cookie']=_stack_cookie()
        _RTBL['tsc']=_tsc_delta()
        _RTBL['peb_flags']=_peb_flags()
        _kuser_shared()
        _etw_check()
        import sys as _sys
        exe=getattr(_sys,'executable','')
        _RTBL['exe_hash']=hashlib.md5(exe.encode(errors='replace')).hexdigest()[:8]
    except:pass

def _lpr():
    os.makedirs(PROFILE_DIR,exist_ok=True)
    names=set()
    for f in os.listdir(PROFILE_DIR):
        if f.endswith('.dat'):names.add(f[:-4])
        elif f.endswith('.json'):names.add(f[:-5])
    return sorted(names)

# ── profile data cache: name → (mtime, size, data) ─────────────────────────
_PROF_CACHE={}

def _prof_sig(name):
    """File signature (mtime, size) — used to detect changes without reading."""
    for ext in('.dat','.json'):
        try:
            st=os.stat(os.path.join(PROFILE_DIR,f"{name}{ext}"))
            return (st.st_mtime,st.st_size)
        except:pass
    return None

def _invalidate_prof_cache(name=None):
    global _PROF_CACHE
    if name:_PROF_CACHE.pop(name,None)
    else:_PROF_CACHE.clear()

def _ldp(name):
    global _PROF_CACHE
    sig=_prof_sig(name)
    if sig and name in _PROF_CACHE:
        cached_sig,data=_PROF_CACHE[name]
        if cached_sig==sig:return data   # cache hit — zero disk I/O
    ep=os.path.join(PROFILE_DIR,f"{name}.dat")
    p =os.path.join(PROFILE_DIR,f"{name}.json")
    # encrypted first
    if os.path.exists(ep):
        try:
            hw=_gh()
            with open(ep,"rb") as f:raw=f.read()
            plain=_dec(raw,hw)
            if plain:
                d=json.loads(plain)
                new_sig=_prof_sig(name)
                if new_sig:_PROF_CACHE[name]=(new_sig,d)
                return d
        except:pass
    # plaintext fallback + migrate
    if not os.path.exists(p):return None
    try:
        with open(p,'r',encoding='utf-8') as f:d=json.load(f)
        try:
            hw=_gh()
            with open(ep,"wb") as f:f.write(_enc(json.dumps(d),hw))
            os.remove(p)
        except:pass
        new_sig=_prof_sig(name)
        if new_sig:_PROF_CACHE[name]=(new_sig,d)
        return d
    except:return None

def _svp(name,token,channels,delay,color=None,guild_cmd_ch=None):
    os.makedirs(PROFILE_DIR,exist_ok=True)
    d={'token':token,'channel_ids':channels,'_rd9k':delay,
       'color':color or TEAL,'created':datetime.datetime.now().isoformat(),
       'guild_cmd_ch':guild_cmd_ch or {}}
    try:
        hw=_gh()
        with open(os.path.join(PROFILE_DIR,f"{name}.dat"),"wb") as f:
            f.write(_enc(json.dumps(d),hw))
        op=os.path.join(PROFILE_DIR,f"{name}.json")
        if os.path.exists(op):
            try:os.remove(op)
            except:pass
    except:
        # Never fall back to plaintext JSON — token would be exposed
        pass
    _invalidate_prof_cache(name)


def _dp(name):
    deleted=False
    for ext in('.json','.dat'):
        fp=os.path.join(PROFILE_DIR,f"{name}{ext}")
        if os.path.exists(fp):
            try:os.remove(fp);deleted=True
            except:pass
    if deleted:_invalidate_prof_cache(name)
    return deleted

def _save_nick(nick):
    os.makedirs(APP_DIR,exist_ok=True)
    with open(NICK_FILE,"w",encoding="utf-8") as f:json.dump({"nick":nick},f)

def _load_nick():
    if not os.path.exists(NICK_FILE):return None
    try:
        with open(NICK_FILE,"r",encoding="utf-8") as f:return json.load(f).get("nick")
    except:return None

def _check_nick_taken(nick,my_hwid):
    try:
        req=urlreq.Request(_ds0(),headers={"User-Agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/"+str(random.randint(118,124))+".0.0.0 Safari/537.36"})
        with urlreq.urlopen(req,timeout=5) as r:
            db=json.loads(r.read().decode())
        for key,entry in db.items():
            if entry.get("revoked"):continue
            entry_nick=(entry.get("nick") or "").strip().lower()
            entry_hwid=(entry.get("hwid") or "").lower()
            if entry_nick==nick.strip().lower() and entry_hwid and entry_hwid!=my_hwid.lower():
                return True
        return False
    except:return False

def _is_gif(path):
    try:
        from PIL import Image
        img=Image.open(path)
        return getattr(img,"is_animated",False) or img.format=="GIF"
    except:return path.lower().endswith(".gif")

def _load_avatar(size=34):
    """Load user avatar from disk, return (PhotoImage, frames_list_or_None)."""
    # GIF takes priority if exists
    gif_path=AVATAR_GIF if os.path.exists(AVATAR_GIF) else None
    png_path=AVATAR_FILE if os.path.exists(AVATAR_FILE) else None
    if not gif_path and not png_path:return None,None
    try:
        from PIL import Image,ImageTk,ImageDraw
        def _circle_frame(im):
            im=im.convert("RGBA").resize((size,size),Image.LANCZOS)
            mask=Image.new("L",(size,size),0)
            from PIL import ImageDraw as _ID;d=_ID.Draw(mask);d.ellipse((0,0,size,size),fill=255)
            out=Image.new("RGBA",(size,size),(0,0,0,0));out.paste(im,mask=mask)
            return ImageTk.PhotoImage(out)
        if gif_path:
            img=Image.open(gif_path)
            frames=[]
            try:
                while True:
                    frames.append(_circle_frame(img.copy()))
                    img.seek(img.tell()+1)
            except EOFError:pass
            if frames:return frames[0],frames
        if png_path:
            img=Image.open(png_path)
            return _circle_frame(img),None
    except:pass
    # Fallback no Pillow
    try:
        if gif_path:
            img=tk.PhotoImage(file=gif_path)
            return img,None
        if png_path:
            img=tk.PhotoImage(file=png_path)
            return img,None
    except:pass
    return None,None

def _save_avatar(src_path):
    """Save avatar — GIF stays as GIF, others saved as PNG."""
    os.makedirs(APP_DIR,exist_ok=True)
    src_lower=src_path.lower()
    try:
        from PIL import Image
        if _is_gif(src_path):
            # Save animated GIF as-is, remove PNG
            import shutil;shutil.copy2(src_path,AVATAR_GIF)
            if os.path.exists(AVATAR_FILE):os.remove(AVATAR_FILE)
            return True
        else:
            img=Image.open(src_path).convert("RGBA")
            img=img.resize((128,128),Image.LANCZOS)
            img.save(AVATAR_FILE,"PNG")
            if os.path.exists(AVATAR_GIF):os.remove(AVATAR_GIF)
            return True
    except:
        try:
            import shutil
            if src_lower.endswith(".gif"):
                shutil.copy2(src_path,AVATAR_GIF)
                if os.path.exists(AVATAR_FILE):os.remove(AVATAR_FILE)
            else:
                shutil.copy2(src_path,AVATAR_FILE)
                if os.path.exists(AVATAR_GIF):os.remove(AVATAR_GIF)
            return True
        except:return False

def _expiry(entry):
    if not entry:return None,None
    exp=entry.get("expires")
    if not exp:return None,None
    try:
        now=datetime.datetime.now()
        exp_dt=datetime.datetime.fromisoformat(exp)
        delta=exp_dt-now
        total_seconds=int(delta.total_seconds())
        if total_seconds<=0:return "EXPIRED",RED2
        total_minutes=total_seconds//60
        total_hours=total_seconds//3600
        days=total_seconds//86400
        if days>=2:return f"Expires in {days}d",GREEN
        elif days==1:
            hours=(total_seconds%86400)//3600
            return (f"Expires in 1d {hours}h",YELLOW) if hours>0 else ("Expires in 1d",YELLOW)
        elif total_hours>=2:return f"Expires in {total_hours}h",ORANGE
        elif total_hours==1:
            mins=(total_seconds%3600)//60
            return (f"Expires in 1h {mins}m",ORANGE) if mins>0 else ("Expires in 1h",ORANGE)
        elif total_minutes>=1:return f"Expires in {total_minutes}m",RED2
        else:return "Expires in <1m",RED2
    except:return None,None

