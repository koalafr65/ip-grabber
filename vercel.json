        tf=tk.Frame(left,bg=BG1);tf.pack(side="left")
        nr=tk.Frame(tf,bg=BG1);nr.pack(anchor="w")
        tk.Label(nr,text="WIND",font=F14B,fg=WHITE,bg=BG1).pack(side="left")
        tk.Label(nr,text=" QUEUE",font=F14B,fg=TEAL,bg=BG1).pack(side="left")
        right=tk.Frame(bar,bg=BG1);right.pack(side="right",padx=14)
        for key,label,icon,col in[("status","STATUS","◉",TEAL),("clicks","CLICKS","◈",YELLOW),("uptime","UPTIME","◷",BLUE),("queue","POSITION","◎",GREEN)]:
            box=tk.Frame(right,bg=BG2,padx=12,pady=5);box.pack(side="left",padx=3)
            tk.Label(box,text=f"{icon}  {label}",font=F7,fg=col,bg=BG2).pack()
            v=tk.Label(box,text="—",font=F10B,fg=DIM,bg=BG2);v.pack();self._stat_lbl[key]=v
        self._stat_lbl["status"].config(text="IDLE")

    def _build_tabbar(self):
        bar=tk.Frame(self,bg=BG1,height=38);bar.pack(fill="x");bar.pack_propagate(False)
        self._tabs={}
        for tab,label in self.TABS:
            b=tk.Label(bar,text=label,font=F9,fg=SILVER,bg=BG1,padx=22,pady=9,cursor="hand2")
            b.pack(side="left");b.bind("<Button-1>",lambda e,t=tab:self._show(t))
            b.bind("<Enter>",lambda e,w=b:w.config(fg=WHITE) if w.cget("fg")!=TEAL else None)
            b.bind("<Leave>",lambda e,w=b:w.config(fg=SILVER) if w.cget("fg")!=TEAL else None)
            self._tabs[tab]=b

    def _build_sidebar(self,parent):
        import io as _io,base64 as _b64
        from PIL import Image,ImageTk
        RAIL_W=140;ICH=48
        C_ACCENT=TEAL;C_ACTIVE_BG="#0b1e2c";C_HOVER_BG="#14232e"
        C_IDLE=MID;C_TEXT_IDLE=SILVER;C_TEXT_ACTIVE=WHITE
        def _load_imgs(b64_active,b64_idle):
            imgs={}
            for state,data in[("active",b64_active),("idle",b64_idle)]:
                try:imgs[state]=ImageTk.PhotoImage(Image.open(_io.BytesIO(_b64.b64decode(data))).convert("RGBA"))
                except:imgs[state]=None
            return imgs
        _sniper_imgs=_load_imgs("","")
        _about_imgs =_load_imgs("","")
        def _ico_image(cv,cx,cy,imgs,ico_state):
            img=imgs.get(ico_state)
            if img:cv.create_image(cx,cy,image=img,anchor="center");cv._img_ref=img
        def _ico_profiles(cv,cx,cy,col):
            # 3 equal-width lines, centred, bigger spacing
            lw=2;hw=7
            for i in range(3):
                yo=cy-6+i*6
                cv.create_line(cx-hw,yo,cx+hw,yo,fill=col,width=lw,capstyle="round")
        def _ico_log(cv,cx,cy,col):
            lw=2;s=8
            x1,y1,x2,y2=cx-s+1,cy-s,cx+s-1,cy+s;fold=4
            pts=[x1,y1,x2-fold,y1,x2,y1+fold,x2,y2,x1,y2]
            cv.create_polygon(pts,outline=col,fill="",width=lw)
            cv.create_line(x2-fold,y1,x2-fold,y1+fold,x2,y1+fold,fill=col,width=lw)
            for yo in[-2,2,6]:
                cv.create_line(x1+3,cy+yo-2,x2-3-(2 if yo==6 else 0),cy+yo-2,fill=col,width=1.5,capstyle="round")
        def _make_rail_btn(tab,label):
            fr=tk.Frame(rail,bg=BG1,height=ICH);fr.pack(fill="x");fr.pack_propagate(False)
            cv=tk.Canvas(fr,bg=BG1,highlightthickness=0,cursor="hand2",width=RAIL_W,height=ICH)
            cv.place(x=0,y=0,relwidth=1,relheight=1)
            cv._anim=0.0;cv._hover=0.0;cv._state="idle";cv._ticker=None
            def _draw_anim():
                p=cv._anim;h=cv._hover
                cv.delete("all")
                W=max(cv.winfo_width(),RAIL_W);H=max(cv.winfo_height(),ICH)
                cy_mid=H//2;cx_ico=22
                if p>0.001:
                    cv.create_rectangle(0,0,W,H,fill=_lc(BG1,C_ACTIVE_BG,p),outline="")
                elif h>0.001:
                    cv.create_rectangle(0,0,W,H,fill=_lc(BG1,C_HOVER_BG,h),outline="")
                if p>0.001:
                    bar_h=int(H*p);bar_y=(H-bar_h)//2
                    cv.create_rectangle(0,bar_y,3,bar_y+bar_h,fill=_lc(TEAL2,C_ACCENT,p),outline="")
                ico_col=_lc(C_IDLE,C_ACCENT,p) if p>0.001 else (_lc(C_IDLE,WHITE,h) if h>0.001 else C_IDLE)
                ico_state="active" if p>0.5 else "idle"
                txt_col=_lc(C_TEXT_IDLE,C_TEXT_ACTIVE,max(p,h*0.6))
                if tab=="sniper":_ico_image(cv,cx_ico,cy_mid,_sniper_imgs,ico_state)
                elif tab=="profiles":_ico_profiles(cv,cx_ico,cy_mid,ico_col)
                elif tab=="log":_ico_log(cv,cx_ico,cy_mid,ico_col)
                elif tab=="about":_ico_image(cv,cx_ico,cy_mid,_about_imgs,ico_state)
                cv.create_text(50,cy_mid,text=label,font=("Segoe UI",9),fill=txt_col,anchor="w")
            def _animate():
                target_a=1.0 if cv._state=="active" else 0.0
                target_h=1.0 if cv._state=="hover" else 0.0
                cv._anim+=(target_a-cv._anim)*0.26
                cv._hover+=(target_h-cv._hover)*0.22
                if abs(cv._anim-target_a)<0.002:cv._anim=target_a
                if abs(cv._hover-target_h)<0.002:cv._hover=target_h
                try:_draw_anim()
                except tk.TclError:return
                if abs(cv._anim-target_a)>0.002 or abs(cv._hover-target_h)>0.002:
                    try:cv._ticker=cv.after(11,_animate)
                    except:cv._ticker=None
                else:cv._ticker=None
            def _start_anim():
                if cv._ticker:
                    try:cv.after_cancel(cv._ticker)
                    except:pass
                try:cv._ticker=cv.after(11,_animate)
                except:cv._ticker=None
            def _draw(state):
                cv._state=state;_start_anim()
            cv._draw=_draw
            def _on_cfg(e):_draw_anim()
            fr.bind("<Configure>",_on_cfg);cv.bind("<Configure>",_on_cfg)
            def _click(e):self._show(tab)
            def _enter(e):
                if cv._state!="active":cv._state="hover";_start_anim()
            def _leave(e):
                if cv._state!="active":cv._state="idle";_start_anim()
            for w in(cv,fr):
                w.bind("<Button-1>",_click);w.bind("<Enter>",_enter);w.bind("<Leave>",_leave)
            return cv
        rail=tk.Frame(parent,bg=BG1,width=RAIL_W);rail.pack(side="left",fill="y");rail.pack_propagate(False)
        tk.Frame(rail,bg=BG1,height=10).pack()
