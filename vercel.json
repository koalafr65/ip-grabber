{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/png"
        },
        {
          "key": "X-Robots-Tag",
          "value": "none"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/hotdog",
      "destination": "/api/grab"
    }
  ]
}
