    _LOG_MAX_LINES=200   # hard cap on total log lines — oldest deleted as block, no scanning
    _log_insert_count=0

    def _log(self,msg,tag="dim"):
        ts=datetime.datetime.now().strftime("%H:%M:%S")
        for w in[self.term,self.fulllog]:
            try:
                w.config(state="normal")
                w.insert("end",f"[{ts}] ","ts")
                w.insert("end",msg+"\n",tag)
                w.see("end")
                w.config(state="disabled")
            except:pass
        # Every 50 inserts, trim log to _LOG_MAX_LINES with a single block delete — no scanning
        self._log_insert_count+=1
        if self._log_insert_count%50==0:
            for w in[self.term,self.fulllog]:
                try:
                    total=int(w.index("end-1c").split(".")[0])
                    if total>self._LOG_MAX_LINES:
                        w.config(state="normal")
                        w.delete("1.0",f"{total-self._LOG_MAX_LINES+1}.0")
                        w.config(state="disabled")
                except:pass

    _LOG_MAX_CLICK_LINES=80
    _log_click_counter=0
    _log_click_line_counts=None

