        self._pf_cv,self._pf=_make_scroll(outer)
        return page

    def _refresh_profiles(self):
        names=_lpr()
        # remember scroll position before any rebuild
        try:scroll_pos=self._pf_cv.yview()[0]
        except:scroll_pos=0.0
        # check if existing cards match — if so, only patch data, never destroy
        existing=getattr(self,'_prof_cards',{})  # name → (card, stripe_lbl, info_lbl)
        existing_names=list(existing.keys())
        if existing_names==names and existing:
            # same list, same order — just update data labels in background
            to_patch=[n for n in names if n in existing]
            def _bg_patch():
                results=[]
                for name in to_patch:
                    try:d=_ldp(name)
                    except:d=None
                    results.append((name,d))
                try:
                    if self.winfo_exists():self.after(0,lambda r=results:_patch_labels(r))
                except:pass
            def _patch_labels(results):
                for name,d in results:
                    if name not in existing:continue
                    _,sb,il=existing[name]
                    try:
                        if not il.winfo_exists():continue
                        if d:
                            tok=d.get('token','');tok_disp=(tok[:6]+"…"+tok[-4:]) if len(tok)>10 else tok
                            ch=", ".join(str(c) for c in d.get('channel_ids',[]))
                            il.config(text=f"Token: {tok_disp}  ·  Channels: {ch}  ·  Delay: {d.get('_rd9k',0.3)}s",fg=MID)
                            sb.config(bg=d.get('color',BG3))
                    except:pass
            th.Thread(target=_bg_patch,daemon=True).start()
            return
        # list changed — full rebuild, then restore scroll
        for w in self._pf.winfo_children():w.destroy()
        self._prof_cards={}
        if not names:
            tk.Label(self._pf,text="No profiles saved.",font=F9,fg=DIM,bg=BG).pack(pady=20,padx=18)
            return
        instant={}
        to_load=[]
        for name in names:
            sig=_prof_sig(name)
            if sig and name in _PROF_CACHE:
                cs,d=_PROF_CACHE[name]
                if cs==sig:instant[name]=d;continue
            to_load.append(name)
        cards={}
        for name in names:
            data=instant.get(name)
            stripe=(data or {}).get("color",BG3) if data else BG3
            card=tk.Frame(self._pf,bg=BG1);card.pack(fill="x",pady=3,padx=18)
            sb=tk.Frame(card,bg=stripe,width=3);sb.pack(side="left",fill="y")
            left=tk.Frame(card,bg=BG1);left.pack(side="left",fill="x",expand=True,padx=14,pady=11)
            tk.Label(left,text=name,font=F10B,fg=WHITE,bg=BG1).pack(anchor="w")
            if data:
                tok=data.get('token','');tok_disp=(tok[:6]+"…"+tok[-4:]) if len(tok)>10 else tok
                ch=", ".join(str(c) for c in data.get('channel_ids',[]))
                il=tk.Label(left,text=f"Token: {tok_disp}  ·  Channels: {ch}  ·  Delay: {data.get('_rd9k',0.3)}s",font=F8,fg=MID,bg=BG1)
            else:
                il=tk.Label(left,text="Loading…",font=F8,fg=DIM,bg=BG1)
            il.pack(anchor="w",pady=(2,0))
            rb=tk.Frame(card,bg=BG1);rb.pack(side="right",padx=10,pady=8)
            PhBtn(rb,text="LOAD",command=lambda n=name:self._load_profile(n),style="primary",w=74,h=28,bg=BG1).pack(side="left",padx=(0,4))
            PhBtn(rb,text="DEL",command=lambda n=name:self._del_profile(n),style="stop",w=62,h=28,bg=BG1).pack(side="left")
            cards[name]=(card,sb,il)
        self._prof_cards=cards
        # restore scroll position after rebuild
        if scroll_pos>0:
            try:self._pf_cv.after_idle(lambda p=scroll_pos:self._pf_cv.yview_moveto(p))
            except:pass
        if to_load:
            def _bg_load():
                results=[]
                for name in to_load:
                    try:d=_ldp(name)
                    except:d=None
                    results.append((name,d))
                try:
                    if self.winfo_exists():self.after(0,lambda r=results:_apply(r))
                except:pass
            def _apply(results):
                for name,d in results:
                    if name not in cards:continue
                    card,sb,il=cards[name]
                    try:
                        if not card.winfo_exists():continue
                        stripe=(d or {}).get("color",RED)
                        sb.config(bg=stripe)
                        if d:
                            tok=d.get('token','');tok_disp=(tok[:6]+"…"+tok[-4:]) if len(tok)>10 else tok
                            ch=", ".join(str(c) for c in d.get('channel_ids',[]))
                            il.config(text=f"Token: {tok_disp}  ·  Channels: {ch}  ·  Delay: {d.get('_rd9k',0.3)}s",fg=MID)
                        else:il.config(text="Could not load profile",fg=RED2)
                    except:pass
            th.Thread(target=_bg_load,daemon=True).start()

    def _load_profile(self,name):
        data=_ldp(name)
        if not data:return
        self._ent_tok.delete(0,"end");self._ent_tok.insert(0,data.get('token',''))
        self._ent_ch.delete(0,"end");self._ent_ch.insert(0,",".join(str(c) for c in data.get('channel_ids',[])))
        self._ent_dly.delete(0,"end");self._ent_dly.insert(0,str(data.get('_rd9k',0.3)))
        self._guild_cmd_ch=dict(data.get('guild_cmd_ch',{}))
        self._ent_pn.delete(0,"end");self._show("sniper",animated=True);self._log(f"Loaded profile '{name}'.","ok")
        try:
            with open(os.path.join(APP_DIR,'last_profile.txt'),'w',encoding='utf-8') as _lf:_lf.write(name)
        except:pass

    def _del_profile(self,name):
        if _emc(self,f"Delete profile '{name}'?"):_dp(name);self._refresh_profiles()

    def _save_profile(self):
        token=self._ent_tok.get().strip();ch_raw=self._ent_ch.get().strip()
        if not token:_em(self,"Error","Token required.");return
        try:
            ch_ids=[int(x.strip()) for x in ch_raw.split(",") if x.strip()]
            if not ch_ids:raise ValueError()
        except:_em(self,"Error","Invalid channel IDs.");return
        try:delay=max(0.05,float(self._ent_dly.get() or "0.3"))
        except:delay=0.3
        prefill=self._ent_pn.get().strip()
        self._osd(token,ch_ids,delay,prefill)

    def _osd(self,token,ch_ids,delay,prefill=""):
        COLORS=[("#e8363d","Red"),("#ffd740","Yellow"),("#ff9800","Orange"),
                ("#40c4ff","Blue"),("#69ff47","Green"),("#ce93d8","Purple"),("#ffffff","White")]
        W2,H2=540,350
        dlg=tk.Toplevel(self);dlg.title("Save Profile");dlg.configure(bg=BG);dlg.resizable(False,False)
        dlg.transient(self);dlg.grab_set();dlg.attributes("-alpha",0.0)
        tk.Frame(dlg,bg=TEAL,height=2).pack(fill="x")
        hdr=tk.Frame(dlg,bg=BG1,height=52);hdr.pack(fill="x");hdr.pack_propagate(False)
        tk.Label(hdr,text="Save Profile",font=F12B,fg=WHITE,bg=BG1).pack(side="left",padx=16)
        tk.Label(hdr,text="Professional preset",font=F7,fg=MID,bg=BG1).pack(side="right",padx=14)
        tk.Frame(dlg,bg=BORDER,height=1).pack(fill="x")
        body=tk.Frame(dlg,bg=BG,padx=16,pady=12);body.pack(fill="both",expand=True)
        summary=tk.Frame(body,bg=BG2,padx=12,pady=8);summary.pack(fill="x")
        tk.Label(summary,text=f"Channels: {len(ch_ids)}",font=F8B,fg=WHITE,bg=BG2).pack(side="left")
        tk.Label(summary,text="  •  ",font=F8B,fg=DIM,bg=BG2).pack(side="left")
        tk.Label(summary,text=f"Delay: {delay:.2f}s",font=F8B,fg=SILVER,bg=BG2).pack(side="left")
        tk.Frame(body,bg=BORDER,height=1).pack(fill="x",pady=(10,10))
        tk.Label(body,text="PROFILE NAME",font=F8B,fg=SILVER,bg=BG).pack(anchor="w")
        name_var=tk.StringVar(value=prefill)
        ent_frame=tk.Frame(body,bg=BORDER,pady=1,padx=1);ent_frame.pack(fill="x",pady=(4,2))
        ent_box=tk.Frame(ent_frame,bg=BG1);ent_box.pack(fill="x")
        tk.Label(ent_box,text="Name",font=F8,fg=MID,bg=BG1,padx=10).pack(side="left")
        ent=tk.Entry(ent_box,textvariable=name_var,font=F10B,bg=BG1,fg=WHITE,insertbackground=TEAL,relief="flat",bd=0)
        ent.pack(side="left",fill="x",expand=True,ipady=9,padx=(0,10))
        ent.bind("<FocusIn>",lambda e:ent_frame.config(bg=TEAL));ent.bind("<FocusOut>",lambda e:ent_frame.config(bg=BORDER))
        hint_row=tk.Frame(body,bg=BG);hint_row.pack(fill="x")
        tk.Label(hint_row,text="3-15 chars, letters/numbers/._-",font=FB,fg=DIM,bg=BG).pack(side="left")
        pcnt=tk.Label(hint_row,text="0/15",font=FB,fg=DIM,bg=BG);pcnt.pack(side="right")
        def _on_pkey(*a):
            n=len(name_var.get());c=min(n,15)
            pcnt.config(text=f"{c}/15",fg=RED2 if n>15 else TEAL if n>0 else DIM)
        ent.bind("<KeyRelease>",_on_pkey);_on_pkey()
        tk.Label(body,text="ACCENT COLOR",font=F8B,fg=SILVER,bg=BG).pack(anchor="w",pady=(10,0))
        existing_color=COLORS[0][0]
        if prefill:
            existing=_ldp(prefill)
            if existing:existing_color=existing.get("color",COLORS[0][0])
        color_var=tk.StringVar(value=existing_color)
        palette=tk.Frame(body,bg=BG2,padx=10,pady=9);palette.pack(fill="x",pady=(4,0))
        preview=tk.Frame(palette,bg=existing_color,width=22,height=22);preview.pack(side="left",padx=(0,10));preview.pack_propagate(False)
        sw_row=tk.Frame(palette,bg=BG2);sw_row.pack(side="left")
        swatches=[]
        def pick(col,sw):
            color_var.set(col);preview.config(bg=col)
            for s in swatches:s.config(highlightthickness=0,bd=2,relief="flat")
            sw.config(highlightthickness=2,highlightbackground=WHITE,highlightcolor=WHITE,bd=0,relief="solid")
        for col,_ in COLORS:
            sw=tk.Label(sw_row,bg=col,width=2,height=1,cursor="hand2",relief="flat",bd=2)
            sw.pack(side="left",padx=3);sw.bind("<Button-1>",lambda e,c=col,s=sw:pick(c,s));swatches.append(sw)
        for idx,(col,_) in enumerate(COLORS):
            if col==existing_color:pick(col,swatches[idx]);break
        else:pick(COLORS[0][0],swatches[0])
        err_var=tk.StringVar()
        tk.Label(body,textvariable=err_var,font=F8,fg=RED2,bg=BG,anchor="w").pack(fill="x",pady=(8,0))
        tk.Frame(dlg,bg=BORDER,height=1).pack(fill="x")
        foot=tk.Frame(dlg,bg=BG1,pady=9,padx=16);foot.pack(fill="x")
        _closing=[False]
        def _close_anim():
            if _closing[0]:return
            _closing[0]=True
            try:
                gx,gy=dlg.winfo_x(),dlg.winfo_y()
            except:
                try:dlg.destroy()
                except:pass
                return
            st=[0]
            def _step():
                if not dlg.winfo_exists():return
                t=st[0]/8
                dlg.attributes("-alpha",max(0.0,1.0-t))
                try:dlg.geometry(f"{W2}x{H2}+{gx}+{gy+int(10*t)}")
                except:pass
                if st[0]<8:
                    st[0]+=1;dlg.after(12,_step)
                else:
                    try:dlg.destroy()
                    except:pass
            _step()
        def do_save():
            import re
            name=name_var.get().strip()
            if not name:err_var.set("Enter a profile name.");return
            if len(name)<3:err_var.set("Minimum 3 characters.");return
            if len(name)>15:err_var.set("Maximum 15 characters.");return
            if not re.match(r"^[a-zA-Z0-9_.\-]+$",name):
                err_var.set("Only letters, numbers, underscore, dot and dash are allowed.");return
            _svp(name,token,ch_ids,delay,color_var.get(),guild_cmd_ch=getattr(self,'_guild_cmd_ch',{}))
            try:
                with open(os.path.join(APP_DIR,'last_profile.txt'),'w',encoding='utf-8') as _lf:_lf.write(name)
            except:pass
            self._ent_pn.delete(0,"end");self._ent_pn.insert(0,name)
            self._log(f"Profile '{name}' saved.","ok")
            _close_anim()
        PhBtn(foot,text="Cancel",command=_close_anim,style="default",w=92,h=32,bg=BG1).pack(side="right",padx=(6,0))
        PhBtn(foot,text="Save Profile",command=do_save,style="primary",w=126,h=32,bg=BG1).pack(side="right")
        dlg.protocol("WM_DELETE_WINDOW",_close_anim)
        ent.bind("<Return>",lambda e:do_save());dlg.bind("<Escape>",lambda e:_close_anim())
        cx=self.winfo_x()+(self.winfo_width()-W2)//2;cy=self.winfo_y()+(self.winfo_height()-H2)//2
